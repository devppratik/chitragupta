# Database Configuration
DB_TYPE=sqlite  # sqlite or postgres
DB_DSN=chitragupta.db  # for sqlite, or postgres connection string

# For PostgreSQL:
# DB_DSN=host=localhost user=chitragupta password=chitragupta dbname=chitragupta port=5432 sslmode=disable

# Storage
STORAGE_PATH=./storage/packages

# Server
PORT=8080
